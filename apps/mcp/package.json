{
  "name": "zine-mcp",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A headless zine press for Step, Send, Attest, and Cite; Mint is registered fail-closed until a durable headless Kademlia indexer is available.",
  "files": [
    "dist/server.js",
    "README.md"
  ],
  "engines": {
    "node": ">=24 <25"
  },
  "bin": {
    "zine-mcp": "dist/server.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/build.mjs",
    "dev": "tsx src/server.ts",
    "prepack": "npm run build",
    "start": "node dist/server.js",
    "test": "tsx --test src/*.test.ts && npm run test:package",
    "test:coverage": "node --import=tsx --test --experimental-test-coverage --test-coverage-lines=85 --test-coverage-branches=62 --test-coverage-functions=80 --test-coverage-include=src/**/*.ts --test-coverage-exclude=src/**/*.test.ts src/*.test.ts && npm run test:package",
    "test:package": "node scripts/package-smoke.mjs",
    "test:relay": "tsc -p tsconfig.integration.json && tsx integration/relay-smoke.ts && tsx integration/recursive-checkpoint-recovery.ts"
  },
  "devDependencies": {
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^24.0.0",
    "diff": "^9.0.0",
    "esbuild": "~0.28.0",
    "nostr-tools": "^2.23.9",
    "tsx": "^4.23.0",
    "typescript": "~5.8.3",
    "zod": "^3.25.0"
  }
}
