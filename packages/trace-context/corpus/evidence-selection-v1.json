{
  "version": 1,
  "contract": "package-local-non-normative-v1",
  "cases": [
    {
      "name": "nil input fails visibly",
      "input": null,
      "expected": {
        "ok": false,
        "code": "MALFORMED_INPUT",
        "stage": "validate",
        "path": "$"
      }
    },
    {
      "name": "bounded history is a typed unsupported policy",
      "input": {
        "version": 1,
        "policy": "bounded-trace-v1",
        "operation": {
          "version": 1,
          "operation": "extend",
          "target": {
            "traceId": "trace",
            "headId": "head",
            "contentHash": "hash",
            "currentText": "Draft"
          },
          "maxContextBytes": 1024,
          "preparedRequestMaxBytes": 2048,
          "reservedPromptBytes": 128
        },
        "candidates": []
      },
      "expected": {
        "ok": false,
        "code": "UNSUPPORTED_POLICY",
        "stage": "validate",
        "receivedPolicy": "bounded-trace-v1"
      }
    },
    {
      "name": "empty selection renders the exact current target once",
      "input": {
        "version": 1,
        "policy": "selected-trace-v1",
        "operation": {
          "version": 1,
          "operation": "extend",
          "target": {
            "traceId": "trace-empty",
            "headId": "head-empty",
            "contentHash": "hash-empty",
            "currentText": "Draft"
          },
          "maxContextBytes": 1024,
          "preparedRequestMaxBytes": 2048,
          "reservedPromptBytes": 128
        },
        "candidates": []
      },
      "expected": {
        "ok": true,
        "renderedContext": "[{\"authority\":\"quoted-data\",\"kind\":\"current-target\",\"text\":\"Draft\",\"version\":1}]",
        "selectedIds": [],
        "effectiveContextBytes": 1024,
        "preparedRequestAvailableBytes": 1920,
        "currentTargetTextBytes": 5,
        "selectionComplete": true
      }
    },
    {
      "name": "lone surrogate constructor is rejected before UTF-8 rendering",
      "construct": {
        "kind": "candidate-text-code-units",
        "textCodeUnits": [55296],
        "input": {
          "version": 1,
          "policy": "selected-trace-v1",
          "operation": {
            "version": 1,
            "operation": "extend",
            "target": {
              "traceId": "trace-unicode",
              "headId": "head-unicode",
              "contentHash": "hash-unicode",
              "currentText": "safe"
            },
            "maxContextBytes": 1024,
            "preparedRequestMaxBytes": 2048,
            "reservedPromptBytes": 0
          },
          "candidates": [
            {
              "version": 1,
              "id": "broken",
              "dedupeKey": "broken",
              "kind": "citation",
              "claimClass": "explicit",
              "source": {
                "kind": "citation",
                "ref": "citation:broken",
                "nodeId": "node-broken",
                "approvedOrder": 0
              },
              "reasons": ["approved-direct-citation"]
            }
          ]
        }
      },
      "expected": {
        "ok": false,
        "code": "MALFORMED_INPUT",
        "stage": "validate",
        "path": "$.candidates[0].text"
      }
    },
