    {
      "name": "text-only projection emits a trace-free citation shape",
      "input": {
        "version": 1,
        "policy": "text-only-v1",
        "operation": {
          "version": 1,
          "operation": "extend",
          "target": {
            "traceId": "target-trace",
            "headId": "target-head",
            "contentHash": "hash",
            "currentText": "Draft"
          },
          "maxContextBytes": 4096,
          "preparedRequestMaxBytes": 8192,
          "reservedPromptBytes": 0
        },
        "candidates": [
          {
            "kind": "process-fact",
            "id": "same-id",
            "dedupeKey": "same-key",
            "text": "LEAK-PROCESS"
          },
          {
            "kind": "explicit-preference",
            "id": "same-id",
            "dedupeKey": "same-key",
            "text": "LEAK-PREFERENCE"
          },
          {
            "version": 1,
            "id": "citation",
            "dedupeKey": "citation",
            "kind": "citation",
            "claimClass": "explicit",
            "source": {
              "kind": "citation",
              "ref": "citation:one",
              "nodeId": "LEAK-NODE",
              "approvedOrder": 0,
              "processStatus": "invalid",
              "traceId": "LEAK-TRACE",
              "range": { "fromUtf16": 999, "toUtf16": 1 }
            },
            "reasons": ["approved-direct-citation"],
            "text": "Quoted body"
          }
        ]
      },
      "expected": {
        "ok": true,
        "renderedContext": "[{\"authority\":\"quoted-data\",\"kind\":\"current-target\",\"text\":\"Draft\",\"version\":1},{\"authority\":\"quoted-data\",\"claimClass\":\"explicit\",\"evidenceId\":\"citation\",\"kind\":\"citation\",\"reasons\":[\"approved-direct-citation\"],\"source\":{\"approvedOrder\":0,\"kind\":\"citation\",\"ref\":\"citation:one\"},\"text\":\"Quoted body\",\"version\":1}]",
        "selectedIds": ["citation"],
        "effectiveContextBytes": 4096,
        "preparedRequestAvailableBytes": 8192,
        "currentTargetTextBytes": 5,
        "selectionComplete": true,
        "forbiddenRenderedSubstrings": [
          "LEAK-PROCESS",
          "LEAK-PREFERENCE",
          "LEAK-NODE",
          "LEAK-TRACE",
          "processStatus",
          "traceId"
        ]
      }
    },
