{
  "name": "@zine/trace-context",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Pure authoring-syntax and deterministic evidence-selection kernel for Zine.",
  "engines": {
    "node": ">=24 <25"
  },
  "exports": {
    ".": "./src/index.ts",
    "./corpus": "./corpus/authoring-syntax-v1.json",
    "./selection-corpus": "./corpus/evidence-selection-v1.json",
    "./selector-parity-corpus": "./corpus/selector-parity-v1.json"
  },
  "scripts": {
    "benchmark": "tsx benchmark/run.ts",
    "benchmark:selector": "tsx benchmark/selection.ts",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck && tsx --test src/*.test.ts benchmark/*.test.ts"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.23.0",
    "typescript": "~5.8.3"
  }
}
